{
    "name": "cheesegrits/filament-military-time",
    "description": "A simple military (24 hour) time form component for Filament",
    "keywords": [
        "cheesegrits",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-military-time"
    ],
    "homepage": "https://github.com/cheesegrits/filament-military-time",
    "support": {
        "issues": "https://github.com/cheesegrits/filament-military-time/issues",
        "source": "https://github.com/cheesegrits/filament-military-time"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Hugh Messenger",
            "email": "hugh.messenger@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/forms": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Cheesegrits\\FilamentMilitaryTime\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cheesegrits\\FilamentMilitaryTime\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cheesegrits\\FilamentMilitaryTime\\MilitaryTimeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
